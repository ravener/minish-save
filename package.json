{
  "name": "minish-save",
  "version": "0.0.1",
  "description": "Read and write save files for The Legend of Zelda: The Minish Cap (GBA)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "zelda",
    "minish-cap",
    "gba",
    "save",
    "eeprom"
  ],
  "license": "MIT"
}
